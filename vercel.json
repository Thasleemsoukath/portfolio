{
  "buildCommand": "echo 'No build needed for static site'",
  "devCommand": "npx http-server",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
